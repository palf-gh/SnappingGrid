                        <connections>
                            <action selector="orientationChanged:" target="-2" id="rvert-action"/>
                        </connections>
                    </button>
                    <!-- Separator before Grid Mode -->
                    <box verticalHuggingPriority="750" fixedFrame="YES" boxType="separator" translatesAutoresizingMaskIntoConstraints="NO" id="sep0">
                        <rect key="frame" x="20" y="318" width="360" height="5"/>
                        <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                    </box>
                    <!-- Grid Mode row (y shifted +50 from original 302→352… keeping at 302 since window expanded at top) -->
                    <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" horizontalCompressionResistancePriority="250" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="labelGridMode">
