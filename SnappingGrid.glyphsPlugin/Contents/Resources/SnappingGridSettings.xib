<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.Cocoa.XIB" version="3.0" toolsVersion="24412" targetRuntime="MacOSX.Cocoa" propertyAccessControl="none" useAutolayout="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.CocoaPlugin" version="24412"/>
        <capability name="System colors introduced in macOS 10.14" minToolsVersion="10.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <customObject id="-2" userLabel="File's Owner" customClass="SettingsPanelController">
            <connections>
                <outlet property="_cancelButton" destination="cancelButton" id="out-cancel"/>
                <outlet property="_labelGridMode" destination="labelGridMode" id="out-label-gridmode"/>
                <outlet property="_labelMainColor" destination="labelMainColor" id="out-label-main-colour"/>
                <outlet property="_captionMainV" destination="labelV1" id="out-caption-main-v"/>
                <outlet property="_captionSubV" destination="labelV2" id="out-caption-sub-v"/>
                <outlet property="_labelMainGrid" destination="labelMainGrid" id="out-label-main"/>
                <outlet property="_labelSubColor" destination="labelSubColor" id="out-label-sub-colour"/>
                <outlet property="_labelSubGrid" destination="labelSubGrid" id="out-label-sub"/>
                <outlet property="_mainColorWell" destination="mainColorWell" id="out-main-colour"/>
                <outlet property="_mainH" destination="mainH" id="out-mainH"/>
                <outlet property="_mainHStep" destination="mainHStep" id="out-mainHStep"/>
                <outlet property="_mainSync" destination="mainSync" id="out-mainSync"/>
                <outlet property="_mainV" destination="mainV" id="out-mainV"/>
                <outlet property="_mainVStep" destination="mainVStep" id="out-mainVStep"/>
                <outlet property="_okButton" destination="okButton" id="out-ok"/>
                <outlet property="_radioDivision" destination="radioDivision" id="out-radio-division"/>
                <outlet property="_radioUnit" destination="radioUnit" id="out-radio-unit"/>
                <outlet property="_snapCheck" destination="snapCheck" id="out-snap"/>
                <outlet property="_subColorWell" destination="subColorWell" id="out-sub-colour"/>
                <outlet property="_subH" destination="subH" id="out-subH"/>
                <outlet property="_subHStep" destination="subHStep" id="out-subHStep"/>
                <outlet property="_subSync" destination="subSync" id="out-subSync"/>
                <outlet property="_subV" destination="subV" id="out-subV"/>
                <outlet property="_subVStep" destination="subVStep" id="out-subVStep"/>
                <outlet property="panel" destination="panel1" id="out-panel"/>
                <outlet property="_labelGridShape" destination="labelGridShape" id="out-label-gridshape"/>
                <outlet property="_radioSquare" destination="radioSquare" id="out-radio-square"/>
                <outlet property="_radioTriangle" destination="radioTriangle" id="out-radio-triangle"/>
                <outlet property="_labelOrientation" destination="labelOrientation" id="out-label-orientation"/>
                <outlet property="_radioHorizontal" destination="radioHorizontal" id="out-radio-horizontal"/>
                <outlet property="_radioVertical" destination="radioVertical" id="out-radio-vertical"/>
            </connections>
        </customObject>
        <customObject id="-1" userLabel="First Responder" customClass="FirstResponder"/>
        <customObject id="-3" userLabel="Application" customClass="NSObject"/>
        <window title="Snapping Grid Settings" allowsToolTipsWhenApplicationIsInactive="NO" autorecalculatesKeyViewLoop="NO" releasedWhenClosed="NO" animationBehavior="default" id="panel1" customClass="NSPanel">
            <windowStyleMask key="styleMask" titled="YES" closable="YES"/>
            <rect key="contentRect" x="0.0" y="0.0" width="400" height="390"/>
            <rect key="screenRect" x="0.0" y="0.0" width="2560" height="1569"/>
            <view key="contentView" id="contentView1">
                <rect key="frame" x="0.0" y="0.0" width="400" height="390"/>
                <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                <subviews>
                    <!-- Grid Shape row -->
                    <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" horizontalCompressionResistancePriority="250" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="labelGridShape">
                        <rect key="frame" x="20" y="362" width="84" height="17"/>
                        <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                        <textFieldCell key="cell" title="Grid Shape:" id="gs-label-cell"/>
                    </textField>
                    <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="radioSquare">
                        <rect key="frame" x="112" y="360" width="100" height="18"/>
                        <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                        <buttonCell key="cell" type="radio" title="Square" bezelStyle="regularSquare" imagePosition="left" alignment="left" inset="2" id="gs-sq-cell"/>
                        <connections>
                            <action selector="shapeChanged:" target="-2" id="rsquare-action"/>
                        </connections>
                    </button>
                    <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="radioTriangle">
                        <rect key="frame" x="222" y="360" width="100" height="18"/>
                        <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                        <buttonCell key="cell" type="radio" title="Triangle" bezelStyle="regularSquare" imagePosition="left" alignment="left" inset="2" id="gs-tri-cell"/>
                        <connections>
                            <action selector="shapeChanged:" target="-2" id="rtriangle-action"/>
                        </connections>
                    </button>
                    <!-- Orientation row -->
                    <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" horizontalCompressionResistancePriority="250" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="labelOrientation">
                        <rect key="frame" x="20" y="336" width="84" height="17"/>
                        <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                        <textFieldCell key="cell" title="Orientation:" id="or-label-cell"/>
                    </textField>
                    <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="radioHorizontal">
                        <rect key="frame" x="112" y="334" width="100" height="18"/>
                        <autoresizingMask key="autoresizingMask" flexibleMinY="YES" flexibleMaxY="YES"/>
                        <buttonCell key="cell" type="radio" title="Horizontal" bezelStyle="regularSquare" imagePosition="left" alignment="left" inset="2" id="or-h-cell"/>
